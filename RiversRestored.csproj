<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net46</TargetFramework>
    <AssemblyName>RiversRestored</AssemblyName>
    <RootNamespace>RiversRestored</RootNamespace>
    <Version>1.5.0</Version>
    <FileVersion>1.5.0</FileVersion>
    <AssemblyVersion>1.5.0</AssemblyVersion>
    <Description>Enables the vanilla-but-disabled river generation system in Farthest Frontier</Description>
    <Company>SageDragoon</Company>
    <Product>Rivers Restored</Product>
    <Copyright>Copyright © SageDragoon 2026</Copyright>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <OutputPath>bin\$(Configuration)\</OutputPath>
    <Platforms>AnyCPU;x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
